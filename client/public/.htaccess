# =============================================================================
# SPA history fallback for the app served at /GabrielGomez/
# Mirrors the proven mirror-client/.htaccess pattern. Apache's Alias points
# /GabrielGomez at this build's dist/ output; this file ships inside dist so it
# lands in the web root on deploy.
# =============================================================================
# Never cache the service worker, its registration, or the manifest, so new
# deploys are picked up promptly (the PWA update prompt depends on this).
<IfModule mod_headers.c>
  <FilesMatch "(sw\.js|registerSW\.js|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

RewriteEngine On
RewriteBase /GabrielGomez/

# Let real files and directories through untouched.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Real hashed assets always exist under /GabrielGomez/assets/*.
RewriteRule ^assets/ - [L]

# Everything else is a client-side route -> hand back index.html.
RewriteRule . index.html [L]
