# Gabriel Gomez API — environment template. Copy to .env on the host (never commit .env).

# Port Apache proxies /GabrielGomez/api to.
GABRIELGOMEZ_PORT=8448

# --- Contact / inquiry email (Resend) ---------------------------------------
# Same provider + domain as Mirror. Put the REAL RESEND_API_KEY only here on the
# host — never commit it.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@theundergroundrailroad.world
EMAIL_FROM_NAME=Gabriel Gomez
SUPPORT_INBOX_EMAIL=theanimaprojectllc@gmail.com
APP_URL=https://www.theundergroundrailroad.world/GabrielGomez
# Max contact submissions per IP per 15-minute window.
CONTACT_RATE_LIMIT=5

# --- SonSoul: Database (catalog + orders) -----------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sonsoul
DB_USER=
DB_PASSWORD=
DB_POOL_LIMIT=10

# --- SonSoul: Admin auth (creator pipeline) ---------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=12h
# Used once by `npm run create-admin` to seed the first admin account.
ADMIN_USERNAME=gabriel
ADMIN_EMAIL=gabrielelythgomez@gmail.com
ADMIN_PASSWORD=

# --- SonSoul: PayPal (sandbox first) ----------------------------------------
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
DISPLAY_APP_NAME=SonSoul

# --- SonSoul: Storage -------------------------------------------------------
# Masters (full audio, stems) live OUTSIDE the web root and are delivered only
# via signed, expiring links after purchase. Previews/images are web-served.
STORAGE_ROOT=/var/www/GabrielGomez-storage
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
PREVIEW_SECONDS=10

# --- SonSoul: Secure preview streaming --------------------------------------
# Signs short-lived preview URLs; falls back to JWT_SECRET if unset.
MEDIA_TOKEN_SECRET=
PREVIEW_TOKEN_TTL_SECONDS=300
PREVIEW_RATE_LIMIT=60
# Only allow preview playback from your own site (Origin/Referer must start with this).
PREVIEW_ALLOWED_ORIGIN=https://www.theundergroundrailroad.world
# Optional: a short voice/producer tag overlaid on previews (anti-theft).
PRODUCER_TAG_PATH=

# --- Phase 2 (Instagram, later) ---------------------------------------------
# IG_LONG_LIVED_TOKEN=
# IG_USER_ID=
